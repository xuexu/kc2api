{
  "name": "kimchi2api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "OpenAI-compatible relay for Kimchi upstream API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "npm run build:admin && tsc -p tsconfig.json",
    "build:admin": "cd admin && npm run build",
    "dev:admin": "cd admin && npm run dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "fastify": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
